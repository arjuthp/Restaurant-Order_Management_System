					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{accessToken}}",
									"type": "string"
								}
							]
						},
						"method": "PATCH",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/reservations/{{reservationId}}/cancel",
							"host": ["{{baseUrl}}"],
							"path": ["reservations", "{{reservationId}}", "cancel"]
