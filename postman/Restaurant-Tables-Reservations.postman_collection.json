							"mode": "raw",
							"raw": "{\n  \"table\": \"{{tableId}}\",\n  \"date\": \"2024-12-25\",\n  \"timeSlot\": \"18:00\",\n  \"numberOfGuests\": 4,\n  \"contactPhone\": \"1234567890\",\n  \"specialRequests\": \"Window seat preferred\"\n}",
