							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Reservation cancelled', () => {",
									"    const response = pm.response.json();",
									"    pm.expect(response.success).to.be.true;",
									"    pm.expect(response.data.status).to.equal('cancelled');",
									"});"
								],
								"type": "text/javascript"
