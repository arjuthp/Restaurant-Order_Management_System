{
	"info": {
		"_postman_id": "table-reservation-api-2024",
		"name": "Restaurant Tables & Reservations API",
		"description": "Complete API testing for Table Management and Reservation System with automated authentication",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"auth": {
		"type": "bearer",
