							"host": ["{{baseUrl}}"],
							"path": ["reservations", "admin", "all"],
							"query": [
								{
									"key": "status",
									"value": "pending",
									"description": "Filter by status (optional)"
								},
								{
									"key": "date",
									"value": "2024-12-25",
									"description": "Filter by date (optional)",
									"disabled": true
								}
							]
						}
					}
				},
